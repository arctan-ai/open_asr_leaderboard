# Hugging Face auth and job submission.
# Required for HF Jobs, private datasets/buckets, and bucket result sync.
HF_TOKEN=hf_...

# Optional job routing/config defaults used by submit_jobs.sh scripts.
# Leave ORG_NAME empty to submit under your personal Hugging Face account.
ORG_NAME=
RESULTS_BUCKET=hf-audio/asr_leaderboard_h200
DATASET_PATH=hf-audio/open-asr-leaderboard
SPACE=
FLAVOR=

# Optional Arctan eval-time audio preprocessing.
# Required only when running with --audio_preprocessor=arctan.
ARCTAN_SDK_KEY=

# Optional Slack notification after score_results prints aggregate WER/RTFx.
# The bot token must have chat:write permission for SLACK_CHANNEL_ID.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# API ASR provider credentials.
# Set only the providers you plan to evaluate.
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
REVAI_API_KEY=
SPEECHMATICS_API_KEY=
AQUAVOICE_API_KEY=
SMALLESTAI_API_KEY=
RESON8_API_KEY=
ZOOM_API_KEY=
AZURE_API_KEY=
SONIOX_API_KEY=

# Passed by api/submit_jobs.sh. The current Azure provider endpoint is fixed in
# code, but keep this here because the job script forwards it.
AZURE_REGION=
