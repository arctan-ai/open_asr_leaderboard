# Hugging Face auth and job submission.
# Required for HF Jobs, private datasets/buckets, and bucket result sync.
HF_TOKEN=hf_...

# Dataset sources shown by the evaluation console.
OPEN_ASR_HF_DATASET_REPO=bettercallaaryan/nc_agent_clips_openasr
OPEN_ASR_LOCAL_DATASET_ROOT=/home/ubuntu/dataset


# Optional job routing/config defaults used by submit_jobs.sh scripts.
# Leave ORG_NAME empty to submit under your personal Hugging Face account.
ORG_NAME=
RESULTS_BUCKET=hf-audio/asr_leaderboard_h200
DATASET_PATH=hf-audio/open-asr-leaderboard
SPACE=
FLAVOR=

# Optional Arctan eval-time audio preprocessing.
# Required only when running with --audio_preprocessor=arctan.
ARCTAN_SDK_KEY=

# Optional ai-coustics VFL 2.1 eval-time audio preprocessing.
# Required only when running with --audio_preprocessor=ai_coustics_vfl_2_1.
# Clone with submodules:
#   git clone --recurse-submodules https://github.com/ai-coustics/lk-noise-canceller-examples
# Then point this at the checkout's noise-canceller directory.
AI_COUSTICS_NOISE_CANCELLER_DIR=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional Slack notification after score_results prints aggregate WER/RTFx.
# The bot token must have chat:write permission for SLACK_CHANNEL_ID.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# API ASR provider credentials.
# Set only the providers you plan to evaluate.
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
REVAI_API_KEY=
SPEECHMATICS_API_KEY=
AQUAVOICE_API_KEY=
SMALLESTAI_API_KEY=
RESON8_API_KEY=
ZOOM_API_KEY=
AZURE_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_ENDPOINT=
SONIOX_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
SARVAM_API_KEY=

# Passed by api/submit_jobs.sh for legacy Azure configuration.
AZURE_REGION=
